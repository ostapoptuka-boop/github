# MongoDB connection string (get from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/trustdrop?retryWrites=true&w=majority

# JWT Secret — random long string for token signing
JWT_SECRET=your-super-secret-jwt-key-change-this-to-random-string-123456

# Email for sending verification (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Server
PORT=3000
NODE_ENV=production

# Frontend URL
FRONTEND_URL=https://hj-goah.onrender.com
